# ── LLM Provider (set ONE) ─────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini         # or gpt-4o, gpt-4-turbo


# ── Server config ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development                  # set to "production" to disable auto-reload

# ── CORS (comma-separated origins, or * for all) ───────────────────────────────
CORS_ORIGINS=*

# ── SMTP email sending (optional — leave blank to disable actual sending) ──────
# Gmail example: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Inquiry Processor
